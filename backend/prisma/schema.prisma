generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String?
  phone      String?
  role       String   @default("runner") // runner | organiser | admin
  city       String?
  bio        String?
  avatarUrl  String?
  isVerified Boolean  @default(false)
  googleId   String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events        Event[]
  registrations Registration[]
  reviews       Review[]
  notifications Notification[]
  fundraisers   Fundraiser[]

  @@map("users")
}

model Event {
  id            String   @id @default(uuid())
  organiserId   String
  title         String
  slug          String   @unique
  city          String
  venue         String
  eventDate     DateTime
  regDeadline   DateTime
  status        String   @default("draft") // draft | pending | live | completed
  coverImageUrl String?
  description   String
  routeMapUrl   String?
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organiser  User                 @relation(fields: [organiserId], references: [id])
  categories EventCategory[]
  reviews    Review[]
  photos     Photo[]
  faqs       EventFaq[]
  campaign   FundraisingCampaign?

  @@map("events")
}

model EventCategory {
  id              String  @id @default(uuid())
  eventId         String
  name            String  // 3K | 5K | 10K | HM | FM | 50K | Ultra
  price           Float
  maxParticipants Int?
  slotsRemaining  Int

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@map("event_categories")
}

model Registration {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String
  bibNumber   String?  @unique
  status      String   @default("pending") // pending | confirmed | cancelled
  amountPaid  Float
  paymentRef  String?
  registeredAt DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id])
  category EventCategory @relation(fields: [categoryId], references: [id])
  result   Result?

  @@map("registrations")
}

model Result {
  id             String  @id @default(uuid())
  registrationId String  @unique
  finishTime     String  // stored as HH:MM:SS
  gunTime        String? // stored as HH:MM:SS
  overallRank    Int
  categoryRank   Int

  registration Registration @relation(fields: [registrationId], references: [id])

  @@map("results")
}

model Review {
  id         String   @id @default(uuid())
  eventId    String
  userId     String
  rating     Int      // 1-5
  body       String
  isVerified Boolean  @default(false)
  isFlagged  Boolean  @default(false)
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Photo {
  id        String   @id @default(uuid())
  eventId   String
  url       String
  bibTag    String?  // bib number tag for search
  caption   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@map("photos")
}

model EventFaq {
  id       String @id @default(uuid())
  eventId  String
  question String
  answer   String
  sortOrder Int   @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_faqs")
}

model Ngo {
  id          String   @id @default(uuid())
  name        String
  description String
  logoUrl     String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  fundraisers Fundraiser[]

  @@map("ngos")
}

model FundraisingCampaign {
  id          String   @id @default(uuid())
  eventId     String   @unique
  goalAmount  Float
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fundraisers Fundraiser[]

  @@map("fundraising_campaigns")
}

model Fundraiser {
  id          String   @id @default(uuid())
  userId      String
  campaignId  String
  ngoId       String
  title       String
  story       String
  goalAmount  Float
  imageUrl    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  campaign  FundraisingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ngo       Ngo                 @relation(fields: [ngoId], references: [id])
  donations Donation[]

  @@unique([userId, campaignId])
  @@map("fundraisers")
}

model Donation {
  id           String   @id @default(uuid())
  fundraiserId String
  donorName    String
  donorEmail   String
  amount       Float
  message      String?
  orderId      String?
  paymentRef   String?
  status       String   @default("pending") // pending | confirmed | failed
  isAnonymous  Boolean  @default(false)
  createdAt    DateTime @default(now())

  fundraiser Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)

  @@map("donations")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // registration_confirmation | payment_receipt | event_reminder_7d | event_reminder_1d | results_published | certificate_ready
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
